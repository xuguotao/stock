# A股量化工具 — 环境变量模板
# 复制为 .env 并填入实际值

# Tushare Pro token (可选, 作为备用数据源)
# 注册地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ClickHouse 数据源
# 本项目默认从这些环境变量读取统一行情数据源；请在本机 .env 中填真实地址和密码。
STOCK_CLICKHOUSE_HOST=localhost
STOCK_CLICKHOUSE_USER=default
STOCK_CLICKHOUSE_PASSWORD=
STOCK_CLICKHOUSE_DATABASE=stock

# 独立数据任务 runner。默认复用上面的 STOCK_CLICKHOUSE_*；只有需要单独覆盖 runner 时再设置。
DATA_OPS_CLICKHOUSE_HOST=
DATA_OPS_CLICKHOUSE_USER=
DATA_OPS_CLICKHOUSE_PASSWORD=
DATA_OPS_CLICKHOUSE_DATABASE=
DATA_OPS_LOG_DIR=logs
DATA_OPS_RUNNER_ID=

# 企业微信机器人Webhook (可选, 用于模拟交易告警)
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
